{
  "manifest_version": 3,
  "name": "MCP Bridge for AI Studio",
  "version": "1.0.0",
  "description": "Brings MCP capabilities to Google AI Studio.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://aistudio.google.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://aistudio.google.com/*",
        "https://aistudio.google.com/app/*",
        "https://aistudio.google.com/prompts/*"
      ],
      "js": ["ui_logic.js", "content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mcp-bridge@magno-emanoel.com"
    }
  }
}
